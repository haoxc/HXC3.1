views:
  - type: table
    name: 表格
    filters:
      and:
        - file.folder.containsAny("03-领域/60-艺术学科/02-艺术创新(S)/02-艺术-数字孪生/02-数字孪生-课题")
        - type == "topic"
    order:
      - file.name
      - description
      - aliases
      - tags
    sort:
      - property: file.ctime
        direction: ASC
    columnSize:
      file.name: 182
      note.description: 224
      note.aliases: 267
