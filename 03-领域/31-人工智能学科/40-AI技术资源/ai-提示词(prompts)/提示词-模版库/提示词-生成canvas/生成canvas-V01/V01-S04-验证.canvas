{
	"nodes":[
		{"id":"group_support","type":"group","content":"支撑层 - 关卡核心要素","x":200,"y":100,"width":350,"height":500,"color":"#e6f2ff"},
		{"id":"group_application","type":"group","content":"应用层 - 实践落地","x":950,"y":100,"width":350,"height":400,"color":"#fff3e0"},
